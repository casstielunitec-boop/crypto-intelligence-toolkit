# ⚙️ Crypto Intelligence Toolkit — Configuration
# Copy this to .env and fill in your keys

# ── Binance API (required for trading bot) ─────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ── Telegram Bot (required for whale tracker alerts) ───
WHALE_BOT_TOKEN=your_telegram_bot_token_here
WHALE_CHAT_ID=your_telegram_chat_id_here

# ── Etherscan API (optional — enables ETH whale tracking) ─
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Mode ───────────────────────────────────────────────
# Set to false when you're ready for real trades
DRY_RUN=true

# ── Binance Base URL (change for testnet) ──────────────
# BINANCE_BASE_URL=https://testnet.binance.vision
